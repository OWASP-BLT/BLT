# =========================
# DJANGO CORE SETTINGS
# =========================
DEBUG=True
SECRET_KEY=your-secret-key-here

# =========================
# SUPERUSER (AUTO CREATE)
# =========================
SUPERUSER=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=admin123

# =========================
# SERVER CONFIG
# =========================
DOMAIN_NAME=localhost
PORT=8000

# =========================
# AUTH CALLBACK URLS
# =========================
CALLBACK_URL_FOR_GITHUB=http://127.0.0.1:8000/
CALLBACK_URL_FOR_GOOGLE=http://127.0.0.1:8000/
CALLBACK_URL_FOR_FACEBOOK=http://127.0.0.1:8000/

# =========================
# AI / API KEYS
# =========================
OPENAI_API_KEY=your-openai-key
LANGCHAIN_API_KEY=your-langchain-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=default
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =========================
# DATABASE
# =========================
DATABASE_URL=sqlite:///db.sqlite3

# =========================
# ERROR TRACKING
# =========================
SENTRY_DSN=https://your-sentry-dsn

# =========================
# INTEGRATIONS (OPTIONAL)
# =========================
SLACK_ID_CLIENT=your-slack-id
SLACK_SECRET_CLIENT=your-slack-secret
SLACK_BOT_TOKEN=your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_WEBHOOK_URL=your-webhook

BLUESKY_USERNAME=your-username
BLUESKY_PASSWORD=your-password

GITHUB_TOKEN=your-github-token
GITHUB_CLIENT_SECRET=your-client-secret
GITHUB_CLIENT_ID=your-client-id

GEMINI_API_KEY=your-gemini-key

# =========================
# POSTGRES (OPTIONAL)
# =========================
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=example_db
POSTGRES_PORT=5432
